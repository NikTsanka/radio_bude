<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="14dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- Cover art (falls back to launcher icon) -->
    <ImageView
        android:id="@+id/widget_art"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@mipmap/launcher_icon"
        android:scaleType="centerCrop"
        android:contentDescription="Radio Hangi" />

    <!-- Station name + song title -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/widget_station_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radio Hangi"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to open"
            android:textSize="11sp"
            android:textColor="#AAFFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="3dp" />

    </LinearLayout>

    <!-- Circular play/pause button -->
    <FrameLayout
        android:id="@+id/widget_play_btn"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/widget_play_btn_bg">

        <ImageView
            android:id="@+id/widget_play_pause_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_widget_play"
            android:contentDescription="Play/Pause" />

    </FrameLayout>

</LinearLayout>
